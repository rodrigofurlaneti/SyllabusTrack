{
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserver,1433;Database=SyllabusTrackDb;User Id=sa;Password=${SA_PASSWORD};TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "SyllabusTrack.API",
    "Audience": "SyllabusTrack.Client",
    "SecretKey": "${JWT_SECRET_KEY}",
    "ExpirationMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
